# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
# MongoDB connection string (required)
# Local:   mongodb://localhost:27017/interview-prep
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/interview-prep
MONGODB_URI=mongodb://localhost:27017/interview-prep

# ─────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens (required, min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_at_least_32_chars

# ─────────────────────────────────────────────────────────────
# AI — Groq (Llama 3.3 70B via LPU inference)
# ─────────────────────────────────────────────────────────────
# Groq API key from https://console.groq.com/keys (required, free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Groq-hosted model to use (optional, defaults to llama-3.3-70b-versatile)
# Options:
#   llama-3.3-70b-versatile  — best quality, ~280 tok/s
#   llama-3.1-8b-instant     — fastest, ~750 tok/s
#   mixtral-8x7b-32768       — long context, ~400 tok/s
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
# Port the Express server listens on (optional, default 5000)
PORT=5000

# Runtime environment — controls logging format and error verbosity
# Values: development | production | test
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────
# Origin of your frontend (required — must be a valid URL)
# Dev: http://localhost:5173
# Prod: https://your-domain.com
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# File uploads
# ─────────────────────────────────────────────────────────────
# Directory for temporary resume uploads (optional, default "uploads")
# Files are deleted immediately after text extraction.
UPLOAD_DIR=uploads
